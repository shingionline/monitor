{
  "apps": [
    {
      "name": "system-monitor",
      "script": "server.js",
      "cwd": "/home/shingi/projects/monitor",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "env_development": {
        "NODE_ENV": "development",
        "PORT": 3000
      },
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/error.log",
      "out_file": "./logs/out.log",
      "log_file": "./logs/combined.log"
    }
  ]
}